# Copy to .env.development for local work or .env.production for a production build.
# If SANITY_PROJECT_ID or SANITY_DATASET are omitted, the app falls back to
# the defaults in client-config.js.
SANITY_PROJECT_ID=y6e2eewm
SANITY_DATASET=production

# Optional: enables authenticated Sanity reads and causes collections that call
# overlayDrafts(...) to prefer draft documents over published ones in builds.
SANITY_READ_TOKEN=

# Required for valid signed FoxyCart ordering links.
FOXYCART_API_KEY=
