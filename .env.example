# Optional in current codebase: falls back to values in client-config.js
SANITY_PROJECT_ID=y6e2eewm
SANITY_DATASET=production

# Optional: enables authenticated Sanity reads and can change build behavior
# by allowing draft overlay in collections that call overlayDrafts(...)
SANITY_READ_TOKEN=

# Required for signed FoxyCart ordering links
FOXYCART_API_KEY=
