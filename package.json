    "@sanity/block-content-to-markdown": "0.0.5",
    "@sanity/client": "^2.0.1",
    "concurrently": "^5.3.0",
    "crypto-js": "^4.0.0",
    "dotenv": "^8.2.0",
    "get-google-fonts": "^1.2.2",
    "gorko": "^0.2.3",
    "groq": "^2.0.1",
    "gulp": "^4.0.2",
    "gulp-clean-css": "^4.3.0",
    "gulp-imagemin": "^7.1.0",
