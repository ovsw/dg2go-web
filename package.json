    "production-win": "SET NODE_ENV=production & gulp && SET NODE_ENV=production & eleventy",
    "lint": "eslint --no-ignore .eleventy.js client-config.js gulpfile.js \"gulp-tasks/**/*.js\" \"src/_data/**/*.js\" \"src/js/**/*.js\" \"src/utils/**/*.js\"",
    "check": "npm run lint && npm run build"
  },
